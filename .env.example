# ─── Agri-Safe Backend Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your actual API keys

# OpenWeatherMap API Key
# Get free key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Google Gemini API Key
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Path to your trained CNN model file
# Supports .h5 (Keras) or .tflite (TFLite)
MODEL_PATH=app/models/crop_disease_model.h5

# Path to agriculture knowledge base (PDF or .txt)
KNOWLEDGE_BASE_PATH=app/data/agriculture_manual.pdf

# Minimum confidence to trust disease detection (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.70

# Rain probability % above which we advise "HOLD SPRAY"
RAIN_THRESHOLD_PERCENT=40
